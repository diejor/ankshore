[sub_resource type="GDScript" id="GDScript_m7umq"]
script/source = "extends Label

func _on_turn_start(team: TeamManager.Team) -> void:
	var team_str: String
	if team == TeamManager.Team.Ally:
		team_str = \"Ally\"
	else:
		team_str = \"Enemy\"
	
	text = team_str
"

[sub_resource type="GDScript" id="GDScript_v1j44"]
script/source = "extends Label

@onready var turn_timer: Timer = %TurnTimer


func _on_seconds_beat_timeout() -> void:
	text = \"Time Left: %ss\" % (int(turn_timer.time_left))


func _on_turn_manager_turn_start(team: TeamManager.Team) -> void:
	turn_timer.start()
"

